{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "GridAgentCore",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "codex",
    "agentcore:project-name": "GridAgentCore"
  },
  "runtimes": [
    {
      "name": "GridAgentCore",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "app/GridAgentCore/",
      "runtimeVersion": "PYTHON_3_14",
      "networkMode": "PUBLIC",
      "protocol": "HTTP",
      "instrumentation": {
        "enableOtel": false
      },
      "envVars": [
        {
          "name": "AWS_REGION",
          "value": "us-west-2"
        },
        {
          "name": "CLAUDE_CODE_USE_BEDROCK",
          "value": "1"
        },
        {
          "name": "ANTHROPIC_MODEL",
          "value": "us.anthropic.claude-sonnet-4-5-20250929-v1:0"
        },
        {
          "name": "GRID_ARTIFACT_DIR",
          "value": "/tmp/grid-agent-core/artifacts"
        },
        {
          "name": "GRID_S3_BUCKET",
          "value": "replace-with-grid-agent-artifact-bucket"
        },
        {
          "name": "GRID_S3_PREFIX",
          "value": "grid-agent-core"
        }
      ]
    }
  ],
  "memories": [],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [],
  "policyEngines": [],
  "configBundles": [],
  "abTests": [],
  "httpGateways": [],
  "harnesses": [],
  "datasets": []
}
