# AWS region used by both Claude Agent SDK Bedrock calls and AgentCore deployment.
AWS_REGION=us-west-2

# Choose one local AWS credential method.
#
# Option A: profile-based credentials. This uses ~/.aws/config and ~/.aws/credentials
# or AWS SSO cache. Recommended for local development because secrets stay out of
# the project directory.
# AWS_PROFILE=default
#
# Option B: explicit temporary credentials in your local .env file. Do not commit
# real values. Leave these commented when using AWS_PROFILE.
AWS_ACCESS_KEY_ID=replace-with-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-secret-access-key
AWS_SESSION_TOKEN=replace-with-session-token-if-using-temporary-credentials

# Claude Agent SDK / Claude Code Bedrock settings.
CLAUDE_CODE_USE_BEDROCK=1
ANTHROPIC_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# Grid AgentCore artifacts.
GRID_ARTIFACT_DIR=.grid_artifacts
GRID_S3_BUCKET=replace-with-grid-agent-artifact-bucket
GRID_S3_PREFIX=grid-agent-core

# Local Grid document source folder.
GRID_DOCS_DIR="/path/to/Grid Docs"
GRID_PARSE_PROVIDER=llamaparse-agentic

# Parse/index-time only. Runtime inference stays on Bedrock through Claude Agent SDK.
LLAMA_CLOUD_API_KEY=replace-with-llamaparse-key-if-using-agentic-parsing
LLAMAPARSE_MAX_PAGES_PER_JOB=50
LLAMAPARSE_TIMEOUT_SECONDS=600
GRID_PARSE_DOCUMENT_CONCURRENCY=4
# Optional post-parse VLM enrichment. When enabled, parsed pages are rendered,
# described with the direct Anthropic API, linked in Markdown, and saved as
# FigureRecord image artifacts for multimodal agent context. GRID_VLM_MODEL
# must be an Anthropic API model ID if set.
GRID_MULTIMODAL_ENRICH=0
GRID_VLM_MODEL=
GRID_VLM_RENDER_DPI=150
GRID_VLM_CONCURRENCY=4
GRID_VLM_MAX_RETRIES=3
GRID_VLM_RETRY_BASE_SECONDS=2
ANTHROPIC_API_KEY=replace-with-anthropic-key-for-vlm-and-batch-indexing
GRID_BATCH_MODEL=claude-3-5-haiku-20241022
VOYAGE_API_KEY=replace-with-voyage-key-if-using-voyage-indexing
COLIVARA_API_KEY=replace-with-colivara-key-if-using-visual-retrieval
COLIVARA_COLLECTION_NAME=grid-agent-core
COLIVARA_API_BASE_URL=https://api.colivara.com
GRID_GRAPHRAG_MODEL=claude-haiku-4-5
GRID_GRAPHRAG_EMBED_MODEL=voyage-law-2

# Local frontend/API defaults.
GRID_LOCAL_API_PORT=8000
VITE_GRID_API_BASE=http://127.0.0.1:8000

# Optional local frontend/proxy forwarding:
# when AGENTCORE_RUNTIME_ARN is set, grid-local-api forwards /api/grid/run to
# the deployed AgentCore runtime instead of running the agent locally.
# Fill this after deployment from agentcore/.cli/deployed-state.json.
AGENTCORE_RUNTIME_ARN=
# Leave blank for the base runtime ARN. Set only for a named runtime endpoint.
AGENTCORE_RUNTIME_QUALIFIER=
